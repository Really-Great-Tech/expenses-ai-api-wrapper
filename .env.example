# Application
NODE_ENV=development
PORT=3000

# Redis Configuration
# For local development use localhost, for Docker Compose deployment Redis is handled internally
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Anthropic (Fallback)
ANTHROPIC_KEY=your_anthropic_api_key_here

LLM_PROVIDER=openai


# LlamaIndex
LLAMAINDEX_API_KEY='your_llamaindex_api_key_here'

# AWS Bedrock Configuration (Primary AI Provider)
BEDROCK_AWS_ACCESS_KEY_ID=your_bedrock_aws_access_key_id_here
BEDROCK_AWS_SECRET_ACCESS_KEY=your_bedrock_aws_secret_access_key_here
BEDROCK_AWS_SESSION_TOKEN=your_bedrock_aws_session_token_here
BEDROCK_AWS_REGION=us-east-1
BEDROCK_MODEL=eu.amazon.nova-pro-v1:0

# Citation Model (Optimized for structured output)
CITATION_MODEL=amazon.nova-micro-v1:0

# LLM-as-Judge Models for Validation (ExpenseComplianceUQLMValidator)
# These models are used as a panel of judges to validate AI responses across different dimensions
# Recommended: Use diverse models for better consensus and reliability
BEDROCK_JUDGE_MODEL_1=eu.amazon.nova-pro-v1:0
BEDROCK_JUDGE_MODEL_2=eu.amazon.nova-lite-v1:0
BEDROCK_JUDGE_MODEL_3=anthropic.claude-3-5-sonnet-20241022-v2:0

# Parallel Validation Configuration (ParallelExpenseComplianceUQLMValidator)
# Enable/disable parallel validation processing
PARALLEL_VALIDATION_ENABLED=true
# Number of validation dimensions to process concurrently (Level 1 parallelization)
VALIDATION_DIMENSION_CONCURRENCY=6
# Number of judges to run concurrently within each dimension (Level 2 parallelization)
VALIDATION_JUDGE_CONCURRENCY=3
# Number of validation jobs to process concurrently for batch operations (Level 3 parallelization)
VALIDATION_JOB_CONCURRENCY=5
# Rate limit for Bedrock API calls per second to avoid throttling
BEDROCK_RATE_LIMIT_PER_SECOND=10
# Enable fallback to sequential processing if parallel validation fails
VALIDATION_FALLBACK_TO_SEQUENTIAL=true

# AWS Textract Configuration (Document Processing)
TEXTRACT_AWS_ACCESS_KEY_ID=your_textract_aws_access_key_id_here
TEXTRACT_AWS_SECRET_ACCESS_KEY=your_textract_aws_secret_access_key_here
TEXTRACT_AWS_REGION=your_textract_aws_region_here

# Document Reader Configuration
DOCUMENT_READER=textract  # Options: llamaparse, textract

# File Upload
MAX_FILE_SIZE=50MB
# Use relative path for local development, absolute path for Docker
UPLOAD_PATH=./uploads
# For Docker production, use: UPLOAD_PATH=/app/uploads


# Job Queue Configuration
QUEUE_CONCURRENCY=10
MAX_RETRY_ATTEMPTS=3
JOB_TIMEOUT=300000

# Processing Optimization
USE_PARALLEL_PROCESSING=true

# Monitoring
ENABLE_SWAGGER=true
ENABLE_THROTTLING=true
THROTTLE_TTL=60
THROTTLE_LIMIT=100


# Job Queue Configuration
QUEUE_CONCURRENCY=10
MAX_RETRY_ATTEMPTS=3
JOB_TIMEOUT=300000

# Processing Optimization
USE_PARALLEL_PROCESSING=true

# Monitoring
ENABLE_SWAGGER=true
ENABLE_THROTTLING=true
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Langfuse Configuration
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_BASE_URL=http://localhost:3001
LANGFUSE_ENABLED=true

# Invoice Splitter Configuration
INVOICE_SPLITTER_ENABLED=true
SPLITTER_LLM_PROVIDER=anthropic  # Options: anthropic, openai
SPLITTER_CONFIDENCE_THRESHOLD=0.75
SPLITTER_MAX_INVOICES=10
